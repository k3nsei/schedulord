# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
max_line_length = 100
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[*.md]
max_line_length = off
insert_final_newline = false
trim_trailing_whitespace = false

[*.go]
indent_style = tab
