# Binaries for programs and plugins
bin/*
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Env
.env
.env.*
!.env.example

# Logs
logs/
*.log

# Editor/IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/mcp.json
!.vscode/settings.json
!.vscode/tasks.json

# OS
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
